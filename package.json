{
  "name": "remote-cli-monorepo",
  "version": "1.0.5",
  "description": "Remote control Claude Code CLI via Feishu bot",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "router:dev": "npm run dev -w @yu_robotics/remote-cli-router",
    "cli:dev": "npm run dev -w @yu_robotics/remote-cli"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "@vitest/ui": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
