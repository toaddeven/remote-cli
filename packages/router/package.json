{
  "name": "@yu_robotics/remote-cli-router",
  "version": "1.1.7",
  "description": "Router server for remote CLI - message forwarding between Feishu and local clients",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "bin": {
    "remote-cli-router": "./bin/remote-cli-router.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts -- start",
    "start": "node dist/cli.js start",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoyu/remote-cli.git",
    "directory": "packages/router"
  },
  "homepage": "https://github.com/xiaoyu/remote-cli#readme",
  "bugs": {
    "url": "https://github.com/xiaoyu/remote-cli/issues"
  },
  "keywords": [
    "claude",
    "cli",
    "remote",
    "feishu",
    "router",
    "websocket"
  ],
  "author": "xiaoyu",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@koa/router": "^12.0.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "axios": "^1.6.7",
    "commander": "^12.0.0",
    "dotenv": "^16.4.1",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  }
}
